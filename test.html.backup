<!DOCTYPE html>
<html>
<head>
<title>Test Content Intelligence API</title>
<style>
body { font-family: Arial; max-width: 900px; margin: 40px auto; padding: 20px; }
textarea { width: 100%; height: 150px; font-size: 14px; }
button { padding: 12px 24px; font-size: 16px; background: #007bff; color: white; border: none; cursor: pointer; }
button:hover { background: #0056b3; }
pre { background: #f4f4f4; padding: 15px; border-radius: 5px; overflow-x: auto; }
.payment-box { background: #fff3cd; border: 1px solid #ffc107; padding: 15px; border-radius: 5px; margin-top: 10px; display: none; }
.payment-box.show { display: block; }
</style>
</head>
<body>
<h2>Content Intelligence API Test</h2>
<p>Paste text below and click Analyze:</p>
<textarea id="text">malba96: Here Senior ML engineer. It helped us to accelerate our internal platform development by improving the scalability of our model router so it can dispatch millions of requests to our internal ML models and a frontend on top so business can interact with the different solutions we develop on our AI team. 20%MurseJ: Every app I pay a sub for I just have my agents build it. Once it's good enough I delete the sub. space-space: Send a prompt that builds a prompt, then does what the prompt entails and if the prompt is not sufficient have it update the prompt automatically please thanks. George Alexander: I built a brain rot crypto tracker that has so many colors and all and lets you track whatever coin you want. Just out of curiosity and boredom tbh.</textarea>
<br><br>
<button onclick="analyze()">Analyze Ideas</button>
<br><br>
<h3>Result:</h3>
<pre id="result">Click Analyze to see results...</pre>
<div id="paymentBox" class="payment-box">
  <strong>Payment Required</strong>
  <p>This endpoint requires $1.00 USDC on Base Sepolia.</p>
  <p id="paymentDetails"></p>
</div>

<script>
async function analyze() {
  const text = document.getElementById('text').value;
  const result = document.getElementById('result');
  const paymentBox = document.getElementById('paymentBox');
  const paymentDetails = document.getElementById('paymentDetails');
  
  result.textContent = 'Analyzing... this may take 10-20 seconds';
  paymentBox.classList.remove('show');
  
  try {
    const res = await fetch('https://content-intelligence-api-xl9z.onrender.com/analyze-ideas', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({text: text, context: 'TikTok comments about AI-built businesses'})
    });
    
    const data = await res.json();
    
    if (res.status === 402) {
      result.textContent = 'Payment Required (402)';
      paymentBox.classList.add('show');
      paymentDetails.textContent = JSON.stringify(data, null, 2);
    } else if (res.status === 200) {
      result.textContent = JSON.stringify(data, null, 2);
    } else {
      result.textContent = 'Error ' + res.status + ': ' + JSON.stringify(data, null, 2);
    }
  } catch (err) {
    result.textContent = 'Error: ' + err.message;
  }
}
</script>
</body>
</html>